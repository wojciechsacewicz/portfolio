{
  "name": "wojtek-sacewicz-portfolio",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "lint": "oxlint src vite.config.ts",
    "test": "vitest run",
    "cloudflare:types": "wrangler types worker-configuration.d.ts",
    "cloudflare:check": "wrangler deploy --dry-run",
    "deploy": "pnpm build && wrangler deploy",
    "check": "pnpm cloudflare:types && pnpm typecheck && pnpm lint && pnpm test && pnpm build && pnpm cloudflare:check"
  },
  "dependencies": {
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.6.1",
    "@react-three/postprocessing": "3.0.4",
    "gsap": "3.15.0",
    "lenis": "1.3.25",
    "motion": "12.42.2",
    "postprocessing": "6.39.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "three": "0.185.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.2",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.185.1",
    "@vitejs/plugin-react": "6.0.3",
    "oxlint": "1.73.0",
    "tailwindcss": "4.3.2",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10",
    "wrangler": "4.110.0"
  }
}
